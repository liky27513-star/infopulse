# AI API (使用Groq - 完全免费！)
GROQ_API_KEY=your_groq_api_key_here

# 新闻 API (可选，作为备用数据源)
NEWS_API_KEY=your_newsapi_key_here

# 加密货币 (可选)
COINGECKO_API_KEY=your_coingecko_key_here

# 金融数据 (可选)
ALPHA_VANTAGE_API_KEY=your_alphavantage_key_here

# 邮件配置 (QQ 邮箱 SMTP - 必需)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_authorization_code_here

# 默认收件人
DEFAULT_RECIPIENT=3421637305@qq.com

# 数据库
DATABASE_URL="file:./dev.db"

# 站点配置
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 管理员密钥 (用于手动触发API)
ADMIN_SECRET_KEY=infopulse_admin_2026

# Cron 密钥
CRON_SECRET=infopulse_cron_2026

# 本地/自托管自动调度（PM2 / npm start 场景建议开启；Vercel 会自动使用 vercel.json）
ENABLE_LOCAL_CRON=true

# 摘要/突发新闻拉取窗口
DIGEST_LOOKBACK_HOURS=24
DIGEST_BUFFER_MINUTES=20
BREAKING_LOOKBACK_HOURS=4
MAX_DIGEST_ARTICLES=45
MAX_BREAKING_ARTICLES=20

# NewsAPI 抓取配置
NEWS_API_LOOKBACK_HOURS=36
NEWS_API_MAX_LOOKBACK_HOURS=72
NEWS_API_PAGE_SIZE=20

# RSS 抓取配置
RSS_ITEMS_PER_FEED=12

# Crossref 期刊抓取配置
CROSSREF_ROWS_PER_JOURNAL=8
CROSSREF_MAILTO=you@example.com
